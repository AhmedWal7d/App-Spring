		{
			"name": "Website",
			"description": "Suggested flow: **Auth** (register / user login / ãÎ) ã **Home** ã **Cart** / **Favorites**. **Home** is public; **Cart**, **Favorites**, and **GET /me** need `Bearer {{token}}` after login or register.",
			"item": [
				{
					"name": "Auth",
					"description": "Same as **Dashboard ã Auth** plus **Register**, **Forgot/Reset password**, **Me**. Admin and user both use `POST /api/auth/login` with different credentials.",
					"item": [
						{
							"name": "Register ã POST /api/auth/register",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"if (pm.response.code === 201) {",
											"  const j = pm.response.json();",
											"  if (j && j.token) pm.collectionVariables.set(\"token\", j.token);",
											"}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"01000000000\",\n  \"lang\": \"en\"\n}"
								},
								"url": "{{baseUrl}}/api/auth/register?lang={{lang}}",
								"description": "Creates `ROLE_USER` account. Body `lang` is optional. On 201, `token` is saved to `{{token}}`."
							}
						},
						{
							"name": "Login ã user (ROLE_USER)",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"if (pm.response.code === 200) {",
											"  const j = pm.response.json();",
											"  if (j && j.token) pm.collectionVariables.set(\"token\", j.token);",
											"}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
								},
								"url": "{{baseUrl}}/api/auth/login?lang={{lang}}",
								"description": "Saves `{{token}}` for **Cart**, **Favorites**, and **GET /me**."
							}
						},
						{
							"name": "Login ã admin (ROLE_ADMIN)",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"if (pm.response.code === 200) {",
											"  const j = pm.response.json();",
											"  if (j && j.token) pm.collectionVariables.set(\"adminToken\", j.token);",
											"}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"admin@ecommerce.local\",\n  \"password\": \"ChangeMe123!\"\n}"
								},
								"url": "{{baseUrl}}/api/auth/login?lang={{lang}}",
								"description": "Saves `{{adminToken}}` for `/api/admin/**`. Credentials from `app.admin.email` / `app.admin.password`."
							}
						},
						{
							"name": "Forgot password ã POST /api/auth/forgot-password",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"user@example.com\"\n}"
								},
								"url": "{{baseUrl}}/api/auth/forgot-password?lang={{lang}}",
								"description": "Sends OTP by email (OTP may not appear in JSON depending on server config)."
							}
						},
						{
							"name": "Reset password ã POST /api/auth/reset-password",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"newpassword123\"\n}"
								},
								"url": "{{baseUrl}}/api/auth/reset-password?lang={{lang}}",
								"description": "OTP from email; new password at least 8 characters."
							}
						},
						{
							"name": "GET ã profile /me",
							"request": {
